# Copy to `.env` and fill in values before running docker compose locally.
# Do not commit real secrets.

# PostgreSQL
POSTGRES_USER=zerorespond
POSTGRES_PASSWORD=change-me
POSTGRES_DB=zerorespond

# Backend API (FastAPI)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@zerorespond-db:5432/${POSTGRES_DB}
JWT_SECRET=change-me-to-a-long-random-string
API_HOST=0.0.0.0
API_PORT=8000

# Wazuh API (Alert Processor polls this address)
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=change-me

# Frontend (optional; baked into compose or runtime)
VITE_API_BASE_URL=http://localhost:8000

# Organization profile (DPDP / reports; set after first deployment)
ORG_NAME=
ORG_DPO_EMAIL=
CERT_IN_CONTACT=incident@cert-in.org.in
